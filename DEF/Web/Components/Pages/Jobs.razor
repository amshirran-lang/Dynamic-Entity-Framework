@page "/jobs"
@using DEF.Domain
@inject HttpClient Http
@inject NavigationManager Nav

<div class="d-flex justify-content-between align-items-center">
<h3>Jobs</h3>
<a href="/jobs/new" class="btn btn-primary">Create New</a>
</div>
@if (jobs != null)
{
    <table class="table table-striped mt-4">
        <thead>
            <tr>
                <th>Title</th>
                <th>Description</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in jobs.GroupBy(j => j.ClientID))
            {
                <tr>
                    <td colspan="4" class="fw-bold bg-light">
                        @group.First().Client?.FirstName @group.First().Client?.LastName
                    </td>
                </tr>
                @foreach (var j in group)
                {
                    <tr>
                        <td>@j.Title</td>
                        <td>@j.Description</td>
                        <td>@j.Status</td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a href="/jobs/edit/@j.Id" class="btn btn-sm btn-outline-primary">Edit</a>
                                <button type="button" class="btn btn-sm btn-outline-danger" @onclick="() => Delete(j.Id)">Delete</button>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
}
else
{
    <p class="mt-4 text-center">Loading...</p>
}

@code
{
    List<Job>? jobs;

    protected override async Task OnInitializedAsync()
    {
        jobs = await Http.GetFromJsonAsync<List<Job>>("api/job");
    }

    async Task Delete(int id)
    {
        await Http.DeleteAsync($"api/job/{id}");
        jobs = await Http.GetFromJsonAsync<List<Job>>("api/job");
    }
}