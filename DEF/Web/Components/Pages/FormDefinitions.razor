@page "/forms"
@using DEF.Domain
@inject HttpClient Http
@inject NavigationManager Nav
@rendermode InteractiveServer

<div class="d-flex justify-content-between align-items-center">
    <h3>Form Definitions</h3>
    <button class="btn btn-primary" @onclick="ShowCreate">Create New</button>
</div>

@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger mt-3">@errorMessage</div>
}

@if (showForm)
{
    <div class="card mt-4">
        <div class="card-body">
            <div class="mb-3">
                <label>Template Name:</label>
                <input class="form-control" @bind="editingForm.Name" />
            </div>
            <div class="mb-3">
                <label>Entity Type:</label>
                <select class="form-select" @bind="editingForm.entity">
                    @foreach (var e in Enum.GetValues<EntityType>())
                    {
                        <option value="@e">@e</option>
                    }
                </select>
            </div>

            <h5>Fields</h5>
            @foreach (var field in editingFields)
            {
                <div class="card mb-2">
                    <div class="card-body">
                        <div class="mb-2">
                            <label>Field Name:</label>
                            <input class="form-control" @bind="field.Name" />
                        </div>
                        <div class="mb-2">
                            <label>Type:</label>
                            <select class="form-select" @bind="field.Type">
                                @foreach (var t in Enum.GetValues<FieldType>())
                                {
                                    <option value="@t">@t</option>
                                }
                            </select>
                        </div>
                        <div class="mb-2">
                            <input type="checkbox" @bind="field.IsRequired" /> Required
                        </div>
                        @if (field.Type == FieldType.DropDown)
                        {
                            <div class="mb-2">
                                <label>Options (comma separated):</label>
                                <input class="form-control" value="@GetOptions(field)"
                                       @onchange="@((ChangeEventArgs e) => SetOptions(field, e.Value?.ToString()))" />
                            </div>
                        }
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveField(field)">Remove Field</button>
                    </div>
                </div>
            }

            <button class="btn btn-outline-secondary btn-sm mt-2" @onclick="AddField">+ Add Field</button>

            <div class="mt-3">
                <button class="btn btn-success" @onclick="SaveForm">Save</button>
                <button class="btn btn-secondary ms-2" @onclick="CancelForm">Cancel</button>
            </div>
        </div>
    </div>
}

<table class="table table-striped mt-4">
    <thead>
        <tr>
            <th>Name</th>
            <th>Entity</th>
            <th>Fields</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (forms != null)
        {
            @foreach (var form in forms)
            {
                <tr>
                    <td>@form.Name</td>
                    <td>@form.entity</td>
                    <td>@form.Fields.Count</td>
                    <td>
                        <button class="btn btn-sm btn-outline-danger" @onclick="() => Delete(form.Id)">Delete</button>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="4" class="text-center">Loading...</td></tr>
        }
    </tbody>
</table>

@code
{
    List<DefineForm>? forms;
    DefineForm editingForm = new();
    List<DefineFields> editingFields = new();
    bool showForm = false;
    string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadForms();
    }

    async Task LoadForms()
    {
        forms = await Http.GetFromJsonAsync<List<DefineForm>>("api/dynamicform");
    }

    void ShowCreate()
    {
        editingForm = new DefineForm();
        editingFields = new List<DefineFields>();
        showForm = true;
    }

    void AddField()
    {
        editingFields.Add(new DefineFields { Key = (editingFields.Count + 1).ToString() });
    }

    void RemoveField(DefineFields field)
    {
        editingFields.Remove(field);
    }

    string GetOptions(DefineFields field) =>
        field.Options != null ? string.Join(", ", field.Options) : "";

    void SetOptions(DefineFields field, string? value)
    {
        field.Options = value?.Split(',').Select(o => o.Trim()).Where(o => !string.IsNullOrEmpty(o)).ToList();
    }

    async Task SaveForm()
    {
        if (string.IsNullOrWhiteSpace(editingForm.Name))
        {
            errorMessage = "Template name is required.";
            return;
        }

        if (editingFields.Any(f => string.IsNullOrWhiteSpace(f.Name)))
        {
            errorMessage = "All field names are required.";
            return;
        }

        editingForm.Fields = editingFields;
        var response = await Http.PostAsJsonAsync("api/dynamicform", editingForm);

        if (response.IsSuccessStatusCode)
        {
            showForm = false;
            errorMessage = null;
            await LoadForms();
        }
        else
        {
            errorMessage = "Failed to save form definition.";
        }
    }

    void CancelForm()
    {
        showForm = false;
        errorMessage = null;
    }

    async Task Delete(int id)
    {
        await Http.DeleteAsync($"api/dynamicform/{id}");
        await LoadForms();
    }
}